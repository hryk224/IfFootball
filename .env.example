# LLM Provider Configuration
# Set ONE of the following API keys to enable LLM features.
# If multiple keys are set, the first available provider is used
# (order: openai > anthropic > gemini > groq).
# Set LLM_PROVIDER to override auto-detection.
#
# Note: When LLM is enabled, scenario data (team names, player names,
# simulation results) is sent to the configured provider.
# Data handling follows the provider's policy.

# Provider override (optional): openai / anthropic / gemini / groq
# LLM_PROVIDER=openai

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1  # for OpenAI-compatible APIs

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini
# GOOGLE_API_KEY=AI...
# GEMINI_MODEL=gemini-2.0-flash

# Groq (recommended for live demo — fast inference)
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile
