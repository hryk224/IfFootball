# LLM Provider Configuration
# Set ONE of the following API keys to enable LLM features.
# If multiple keys are set, the first available provider is used
# (order: openai > anthropic > gemini > groq).
# Set LLM_PROVIDER to override auto-detection.

# Provider override (optional): openai / anthropic / gemini / groq
# LLM_PROVIDER=openai

# Model override (optional): defaults to provider-specific model
# LLM_MODEL=gpt-4o-mini

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
# GOOGLE_API_KEY=AI...

# Groq (for live demo / fast inference)
# GROQ_API_KEY=gsk_...
